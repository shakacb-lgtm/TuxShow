{
  "name": "tuxshow",
  "productName": "TuxShow",
  "version": "1.5.0",
  "description": "Projection Mapping and Show Control",
  "author": "Christopher Baker <tuxshowscpm@gmail.com>",
  "homepage": "https://github.com/shakacb-lgtm/TuxShow",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron . --no-sandbox\"",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "vite build && electron-builder --linux"
  },
  "dependencies": {
    "easymidi": "^3.2.0",
    "lucide-react": "^0.368.0",
    "node-osc": "^9.1.7",
    "qrcode.react": "^3.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "webm-duration-fix": "^1.0.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.0.0",
    "vite": "^8.0.11"
  },
  "build": {
    "appId": "com.tuxshow.app",
    "files": [
      "**/*",
      "dist/**/*"
    ],
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "AudioVideo",
      "icon": "public/icon.png"
    },
    "directories": {
      "output": "release"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shakacb-lgtm/TuxShow.git"
  },
  "keywords": [],
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/shakacb-lgtm/TuxShow/issues"
  }
}
