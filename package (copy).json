{
  "name": "tuxshow",
  "productName": "TuxShow",
  "version": "1.0.0",
  "description": "Professional Projection Mapping and Show Control",
  "author": "Your Name <you@example.com>",
  "homepage": "https://github.com/shakacb-lgtm/TuxShow",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron . --no-sandbox\"",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "vite build && electron-builder --linux"
  },
  "dependencies": {
    "easymidi": "^3.0.0",
    "lucide-react": "^0.368.0",
    "node-osc": "^9.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^4.0.0",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.tuxshow.app",
    "files": [
      "**/*",
      "dist/**/*"
    ],
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "AudioVideo",
      "icon": "build/icon.png"
    },
    "directories": {
      "output": "release"
    }
  }
}
